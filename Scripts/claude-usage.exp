#!/usr/bin/expect -f

# Claude's slash commands require an interactive terminal. This script creates
# a short-lived PTY, opens /usage, leaves after the screen has loaded, and exits.
set timeout 25
set claude_executable [lindex $argv 0]

spawn -noecho $claude_executable --safe-mode --ax-screen-reader

proc abort_child {message code} {
    global spawn_id
    puts stderr $message
    catch {send -i $spawn_id -- "\003"}
    after 250
    catch {close -i $spawn_id}
    catch {wait -i $spawn_id}
    exit $code
}

expect {
    -re {[$❯]} {}
    timeout {
        abort_child "Timed out waiting for Claude Code to start" 2
    }
    eof {
        puts stderr "Claude Code exited before showing its prompt"
        exit 2
    }
}

send -- "/usage\r"
expect {
    -re {Current week \(Fable\)} {}
    timeout {
        abort_child "Timed out waiting for Claude usage data" 3
    }
    eof {
        puts stderr "Claude Code exited before /usage loaded"
        exit 3
    }
}
expect {
    -re {[0-9]+%[[:space:]]+used} {}
    timeout {
        abort_child "Timed out waiting for Fable usage" 3
    }
}
after 300
send -- "\033"
expect {
    -re {[$❯]} {}
    timeout {
        abort_child "Timed out returning from Claude usage" 4
    }
    eof {
        exit 4
    }
}
after 150
send -- "/exit\r"

expect {
    eof {}
    timeout {
        abort_child "Timed out waiting for Claude Code to exit" 4
    }
}
